# Tesla API credentials
TESLA_EMAIL=
TESLA_PASSWORD=

# Postgres + TimescaleDB
DATABASE_URL=postgresql://user:pass@localhost:5432/wattwise

# Resend email service
RESEND_API_KEY=
RESEND_FROM_EMAIL=wattwise@yourdomain.com
REPORT_RECIPIENT_EMAIL=you@email.com

# Anthropic (weekly report AI narrative)
ANTHROPIC_API_KEY=

# CORS (comma-separated origins for frontend)
CORS_ORIGINS=http://localhost:3000

# Tesla token storage path (optional, defaults to .tesla_token)
TESLA_TOKEN_PATH=.tesla_token
